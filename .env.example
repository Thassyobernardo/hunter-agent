# ── Required ────────────────────────────────────────────────────────
# Cerebras API key for LLaMA-3.1 inference
# Get yours at: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Apify (optional — powers Twitter/X and LinkedIn scrapers) ────────
# Get token at: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# ── Agent config ─────────────────────────────────────────────────────
# Comma-separated keywords to hunt for leads
KEYWORDS=python developer,automation,web scraping,fastapi,flask,django,api integration

# How often to run a scan (in hours)
SCAN_INTERVAL_HOURS=3

# ── PostgreSQL ────────────────────────────────────────────────────────
# Provided automatically by the Railway PostgreSQL service.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/hunter

# Directory where generated project ZIPs are stored.
# Default: builds/ in the working directory.
# With a Railway Volume: BUILDS_DIR=/data/builds
BUILDS_DIR=builds

# ── Flask ─────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret
PORT=5000
FLASK_DEBUG=false
